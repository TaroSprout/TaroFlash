#!/usr/bin/env zsh
# Drift-check helper. The declarative schema files in supabase/schemas/ are
# hand-organized by domain — this tool does NOT write to them. It dumps the
# local database and produces a raw, type-bucketed snapshot in a git-ignored
# scratch dir for manual comparison against the hand-organized declarations.
set -euo pipefail
cd "$(dirname "$0")/.."

snapshot="supabase/.schema-snapshot"
tmp="$(mktemp)"
docker exec supabase_db_TaroFlash pg_dump -U postgres -d postgres \
  --schema-only --schema=public --schema=tests > "$tmp"

rm -rf "$snapshot"
python3 scripts/split-schema.py "$tmp" "$snapshot"
rm "$tmp"

echo "Wrote type-bucketed snapshot to $snapshot/ (git-ignored)."
echo "Compare it by hand against supabase/schemas/ to spot drift; nothing under"
echo "supabase/schemas/ was touched."
